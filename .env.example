# Optional — enables live AI generation on /demo. Without it, the app runs in Sample Mode.
OPENAI_API_KEY=sk-...your key here...

# Optional — point at any OpenAI-compatible provider (defaults to OpenAI).
# Example (Groq): fast free-tier inference for the live demo.
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=openai/gpt-oss-120b
