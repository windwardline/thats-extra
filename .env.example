# Optional — enables live AI generation on /demo. Without it, the app runs in Sample Mode.
# Groq has a free tier and is the fastest option for a live demo.
GROQ_API_KEY=gsk_...your key here...

# Optional overrides. Groq speaks the OpenAI wire protocol, so any
# OpenAI-compatible endpoint works here.
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional — forwards successful generations to the live Zapier automation.
# ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/...
